@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Online Exam</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
@{
    var user = Context.Session.GetString("User");
    var role = Context.Session.GetString("Role");
}
<body>
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-3">
        <div class="container">
            <ul class="navbar-nav flex-grow-1">
                @if (string.IsNullOrEmpty(user))
                {
                    <a class="nav-link" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                    <a class="nav-link" asp-controller="Auth" asp-action="Register">Đăng ký</a>
                }
                else
                {
                    <span class="nav-link">
                        Xin chào @user (@role)
                    </span>
                    @if (role == "Teacher")
                    {
                        <a class="nav-link" asp-controller="Teacher" asp-action="Index">Giáo viên</a>
                    }
                    else if (role == "Student")
                    {
                        <a class="nav-link" asp-controller="Student" asp-action="Index">Sinh viên</a>
                    }
                    <a class="nav-link" asp-controller="Auth" asp-action="Logout">Đăng xuất</a>
                }
            </ul>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>