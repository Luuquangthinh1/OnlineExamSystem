@{
    ViewData["Title"] = "Quên mật khẩu";
}
<style>
    body {
        background: #f4f6f9;
        font-family: Arial;
    }

    .forgot-container {
        width: 400px;
        margin: 80px auto;
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }
        .forgot-container h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #333;
        }

    .input-group {
        margin-bottom: 18px;
    }
        .input-group label {
            display: block;
            margin-bottom: 6px;
            font-weight: bold;
            color: #444;
        }

        .input-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-size: 15px;
        }

            .input-group input:focus {
                border-color: #4CAF50;
                outline: none;
            }
    .btn-reset {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #4CAF50, #2E8B57);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        cursor: pointer;
        transition: 0.3s;
    }
        .btn-reset:hover {
            transform: scale(1.03);
            background: linear-gradient(135deg, #45a049, #1f6f43);
        }
    .error {
        color: red;
        text-align: center;
        margin-top: 15px;
    }
    .success {
        color: green;
        text-align: center;
        margin-top: 15px;
    }
    .back-login {
        text-align: center;
        margin-top: 20px;
    }

        .back-login a {
            text-decoration: none;
            color: #007bff;
            font-weight: bold;
        }
            .back-login a:hover {
                text-decoration: underline;
            }
</style>
<div class="forgot-container">
    <h2>Quên mật khẩu</h2>
    <form method="post">
        <div class="input-group">
            <label>Username</label>
            <input type="text"
                   name="username"
                   placeholder="Nhập username"
                   required />
        </div>
        <div class="input-group">
            <label>Mật khẩu mới</label>
            <input type="password"
                   name="newPassword"
                   placeholder="Nhập mật khẩu mới"
                   required />
        </div>
        <div class="input-group">
            <label>Xác nhận mật khẩu</label>
            <input type="password"
                   name="confirmPassword"
                   placeholder="Nhập lại mật khẩu"
                   required />
        </div>
        <button type="submit" class="btn-reset">
            Đổi mật khẩu
        </button>
    </form>
    @if (ViewBag.Error != null)
    {
        <div id="errorMessage" class="error">
            @ViewBag.Error
        </div>
        <script>
                setTimeout(function () {
                    document.getElementById("errorMessage").style.display = "none";
                }, 3000);
        </script>
    }
    @if (ViewBag.Success != null)
    {
        <div id="successMessage" class="success">
            @ViewBag.Success
        </div>
        <script>
                setTimeout(function () {
                    document.getElementById("successMessage").style.display = "none";
                }, 3000);
        </script>
    }
    <div class="back-login">
        <a asp-controller="Auth"
               asp-action="Login">
            Quay lại đăng nhập
        </a>
    </div>
</div>