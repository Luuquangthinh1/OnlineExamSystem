@{
    ViewData["Title"] = "Register";
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header text-center">
                    <h3>Đăng Ký</h3>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div id="errorMessage"
                             class="alert alert-danger">
                            @ViewBag.Error

                        </div>
                        <script>
                        setTimeout(function () {
                            var error =
                            document.getElementById(
                                "errorMessage");
                                if (error) {
                                    error.style.display = "none";
                                }
                        }, 3000);
                        </script>
                    }
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">
                                Tên tài khoản
                            </label>

                            <input type="text"
                                   name="username"
                                   class="form-control" />
                        </div>
                        <div class="mb-3">

                            <label class="form-label">
                                Mật khẩu
                            </label>
                            <input type="password"
                                   name="password"
                                   class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">
                                Vai trò
                            </label>
                            <select name="role"
                                    class="form-select">
                                <option value="Student">
                                    Student
                                </option>
                                <option value="Teacher">
                                    Teacher
                                </option>
                                <option value="Admin">
                                    Admin
                                </option>
                            </select>
                        </div>
                        <button type="submit"
                                class="btn btn-primary w-100">
                            Đăng Ký
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>