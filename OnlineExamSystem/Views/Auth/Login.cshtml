@{
    ViewData["Title"] = "Đăng nhập";
}
<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg border-0 p-4 login-box">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">Chào mừng trở lại</h2>
            <p class="text-muted">Đăng nhập để tiếp tục sử dụng hệ thống</p>
        </div>
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Tên đăng nhập</label>
                <input name="username"
                       placeholder="Nhập tên đăng nhập"
                       class="form-control custom-input" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Mật khẩu</label>
                <input name="password"
                       type="password"
                       placeholder="Nhập mật khẩu"
                       class="form-control custom-input" />
            </div>
            <button class="btn btn-primary w-100 login-btn">
                Đăng nhập
            </button>
        </form>
        @if (ViewBag.Error != null)
        {
            <div id="error" class="alert alert-danger mt-3 text-center">
                @ViewBag.Error
            </div>
        }
        <div class="text-center mt-3">
            <a asp-controller="Auth"
                   asp-action="ForgotPassword"
                   class="text-decoration-none fw-semibold text-primary">
                Quên mật khẩu?
            </a>
        </div>
        <div class="mt-2 text-center">
            <span class="text-muted">Chưa có tài khoản?</span>
            <a asp-action="Register"
                   class="text-decoration-none fw-bold text-success">
                Đăng ký ngay
            </a>
        </div>
    </div>
</div>
<style>
    body {
        background: linear-gradient(135deg, #ffffff, #ffffff);
        font-family: 'Segoe UI', sans-serif;
    }

    .login-box {
        width: 400px;
        border-radius: 20px;
        background: white;
    }

    .custom-input {
        height: 45px;
        border-radius: 10px;
        border: 1px solid #ced4da;
        transition: 0.3s;
    }

        .custom-input:focus {
            border-color: #4facfe;
            box-shadow: 0 0 8px rgba(79, 172, 254, 0.5);
        }

    .login-btn {
        height: 45px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: bold;
        transition: 0.3s;
    }

        .login-btn:hover {
            transform: scale(1.03);
        }

    #error {
        border-radius: 10px;
    }
</style>
<script>
    setTimeout(() => {
        let e = document.getElementById("error");
        if (e) e.style.display = "none";
    }, 3000);
</script>