@model List<ExamSession>
@{
    ViewData["Title"] = "Danh sách kỳ thi";
}
<style>
    .session-container {
        width: 90%;
        margin: auto;
    }

    .session-card {
        background: white;
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .btn-enter {
        background: #007bff;
        color: white;
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-enter:hover {
            background: #0056b3;
        }
</style>
<div class="session-container">
    <h2>Danh sách kỳ thi</h2>
    @foreach (var s in Model)
    {
        <div class="session-card mb-4">

            <h3>

                @s.Name

            </h3>

            <p>

                Số đề thi:
                @(s.Exams?.Count ?? 0)

            </p>

            @if (s.Exams != null && s.Exams.Any())
            {
                @foreach (var exam in s.Exams)
                {
                    var now = DateTime.Now;

                    bool available =
                        now >= exam.StartTime
                        &&
                        now <= exam.EndTime;

                    <div class="card p-3 mb-3 shadow-sm">

                        <h5>

                            @exam.Title

                        </h5>

                        <div class="text-muted small mb-2">

                            <div>

                                Mở đề:
                                @exam.StartTime

                            </div>

                            <div>

                                Đóng đề:
                                @exam.EndTime

                            </div>

                            <div>

                                Thời gian:
                                @exam.Duration phút

                            </div>
                            <p class="mt-2">

                                <strong>
                                    Số lần được làm:
                                </strong>

                                @exam.MaxAttempts

                            </p>

                        </div>

                        @if (available)
                        {
                            <a asp-controller="Student"
                               asp-action="Start"
                               asp-route-id="@exam.Id"
                               class="btn btn-success">
                                Vào thi
                            </a>
                        }
                        else if (now < exam.StartTime)
                        {
                            <button class="btn btn-warning"
                                    disabled>

                                Chưa đến giờ thi

                            </button>
                        }
                        else
                        {
                            <button class="btn btn-danger"
                                    disabled>

                                Đã hết giờ thi

                            </button>
                        }

                    </div>
                }
            }
            else
            {
                <div class="alert alert-secondary">

                    Chưa có đề thi.

                </div>
            }

        </div>
    }
</div>