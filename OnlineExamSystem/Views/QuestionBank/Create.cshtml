@model OnlineExamSystem.Models.QuestionBank
@using OnlineExamSystem.Models.Enums

@{
    ViewData["Title"] = "Thêm câu hỏi";
}

<div class="container mt-4">

    <h2 class="mb-4">
        Thêm câu hỏi
    </h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <form method="post"
          enctype="multipart/form-data">

        <div class="card shadow-sm mb-4">

            <div class="card-header">

                <h5 class="mb-0">
                    Thông tin câu hỏi
                </h5>

            </div>

            <div class="card-body">

                <div class="mb-3">

                    <label class="form-label">
                        Nội dung câu hỏi
                    </label>

                    <textarea asp-for="Content"
                              id="questionContent"
                              class="form-control"
                              rows="4"></textarea>

                </div>

                <div class="row">

                    <div class="col-md-4">

                        <label class="form-label">
                            Loại câu hỏi
                        </label>

                        <select asp-for="Type"
                                id="questionType"
                                class="form-select">

                            @foreach (var t in Enum.GetValues(typeof(QuestionType)))
                            {
                                <option value="@t">
                                    @t
                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Môn học
                        </label>

                        <input asp-for="Subject"
                               class="form-control" />

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Độ khó
                        </label>

                        <input asp-for="Difficulty"
                               class="form-control" />

                    </div>

                </div>

                <div class="row mt-3">

                    <div class="col-md-6">

                        <label class="form-label">
                            Điểm
                        </label>

                        <input asp-for="Score"
                               type="number"
                               min="0.05"
                               step="0.05"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Audio
                        </label>

                        <input type="file"
                               name="audioFile"
                               class="form-control" />

                    </div>

                </div>

            </div>

        </div>

        <div id="singleChoiceBox"
             class="card shadow-sm mb-4 type-box">

            <div class="card-header">
                Single Choice
            </div>

            <div class="card-body">

                @{
                    var letters =
                    new[] { "A", "B", "C", "D" };
                }

                @for (int i = 0; i < 4; i++)
                {
                    <div class="d-flex align-items-center mb-3">

                        <input type="radio"
                               name="answers"
                               value=""
                               class="form-check-input me-2 answer-selector" />

                        <label class="me-2 fw-bold">
                            @letters[i].
                        </label>

                        <input name="options"
                               class="form-control option-input"
                               placeholder="Đáp án @letters[i]" />

                    </div>
                }

            </div>

        </div>
        <div id="multipleChoiceBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                Multiple Choice
            </div>

            <div class="card-body">

                @for (int i = 0; i < 4; i++)
                {
                    <div class="d-flex align-items-center mb-3">

                        <input type="checkbox"
                               name="answers"
                               value=""
                               class="form-check-input me-2 answer-selector" />

                        <label class="me-2 fw-bold">
                            @letters[i].
                        </label>

                        <input name="options"
                               class="form-control option-input"
                               placeholder="Đáp án @letters[i]" />

                    </div>
                }

            </div>

        </div>

        <div id="trueFalseBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                True / False
            </div>

            <div class="card-body">

                <div class="form-check mb-2">

                    <input type="radio"
                           name="answers"
                           value="Đúng"
                           class="form-check-input" />

                    <label class="form-check-label">
                        Đúng
                    </label>

                </div>

                <div class="form-check">

                    <input type="radio"
                           name="answers"
                           value="Sai"
                           class="form-check-input" />

                    <label class="form-check-label">
                        Sai
                    </label>

                </div>

            </div>

        </div>
        <div id="matchingBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                Matching
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6">

                        <h6 class="fw-bold text-primary">
                            Cột A
                        </h6>

                        @for (int i = 0; i < 4; i++)
                        {
                            <input name="options"
                                   class="form-control mb-2"
                                   placeholder="Cột A @(i + 1)" />
                        }

                    </div>

                    <div class="col-md-6">

                        <h6 class="fw-bold text-success">
                            Cột B
                        </h6>

                        @for (int i = 0; i < 4; i++)
                        {
                            <input name="answers"
                                   class="form-control mb-2"
                                   placeholder="Cột B @(i + 1)" />
                        }

                    </div>

                </div>

            </div>

        </div>

        <div id="fillBlankBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                Fill Blank
            </div>

            <div class="card-body">

                <input name="answers"
                       class="form-control"
                       placeholder="Đáp án" />

            </div>

        </div>

        <div id="essayBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                Essay
            </div>

            <div class="card-body">

                <textarea name="answers"
                          rows="6"
                          class="form-control"
                          placeholder="Đáp án tự luận"></textarea>

            </div>

        </div>

        <button class="btn btn-success">
            Lưu câu hỏi
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">

            Quay lại

        </a>

    </form>

</div>

<script>

    const typeSelect =
        document.getElementById(
            "questionType");

    const boxes =
    {
        "SingleChoice":
            document.getElementById(
                "singleChoiceBox"),

        "MultipleChoice":
            document.getElementById(
                "multipleChoiceBox"),

        "TrueFalse":
            document.getElementById(
                "trueFalseBox"),

        "Matching":
            document.getElementById(
                "matchingBox"),

        "FillBlank":
            document.getElementById(
                "fillBlankBox"),

        "Essay":
            document.getElementById(
                "essayBox")
    };

    function updateQuestionType()
    {
        document
            .querySelectorAll(".type-box")
            .forEach(x =>
            {
                x.classList.add("d-none");
            });

        const selected =
            typeSelect.value;

        if (boxes[selected])
        {
            boxes[selected]
                .classList
                .remove("d-none");
        }
    }

    typeSelect.addEventListener(
        "change",
        updateQuestionType);

    updateQuestionType();

    document.addEventListener(
     "input",
     function (e)
     {
         if (
             e.target.classList.contains(
                 "option-input"))
         {
             const row =
                 e.target.closest(".d-flex");

             const selector =
                 row.querySelector(
                     ".answer-selector");

             if (selector)
             {
                 selector.value =
                     e.target.value;
             }
         }
     });

</script>