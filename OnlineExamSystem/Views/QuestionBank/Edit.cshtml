@model OnlineExamSystem.Models.QuestionBank
@using OnlineExamSystem.Models.Enums
@using System.Text.Json

@{
    ViewData["Title"] = "Sửa câu hỏi";

    var options =
        string.IsNullOrEmpty(Model.OptionsJson)
        ? new List<string>()
        : JsonSerializer.Deserialize<List<string>>
            (Model.OptionsJson)
            ?? new List<string>();

    var answers =
        string.IsNullOrEmpty(Model.CorrectAnswerJson)
        ? new List<string>()
        : JsonSerializer.Deserialize<List<string>>
            (Model.CorrectAnswerJson)
            ?? new List<string>();

    var letters =
        new[] { "A", "B", "C", "D" };
}

<div class="container mt-4">

    <h2 class="mb-4">
        Sửa câu hỏi
    </h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <form method="post"
          enctype="multipart/form-data">

        <input asp-for="Id"
               type="hidden" />

        <div class="card shadow-sm mb-4">

            <div class="card-header">
                <h5 class="mb-0">
                    Thông tin câu hỏi
                </h5>
            </div>

            <div class="card-body">

                <div class="mb-3">

                    <label class="form-label">
                        Nội dung câu hỏi
                    </label>

                    <textarea asp-for="Content"
                              class="form-control"
                              rows="4"></textarea>

                </div>

                <div class="row">

                    <div class="col-md-4">

                        <label class="form-label">
                            Loại câu hỏi
                        </label>

                        <select asp-for="Type"
                                id="questionType"
                                class="form-select">

                            @foreach (var t in Enum.GetValues(typeof(QuestionType)))
                            {
                                <option value="@t">
                                    @t
                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Môn học
                        </label>

                        <input asp-for="Subject"
                               class="form-control" />

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Độ khó
                        </label>

                        <input asp-for="Difficulty"
                               class="form-control" />

                    </div>

                </div>

                <div class="row mt-3">

                    <div class="col-md-6">

                        <label class="form-label">
                            Điểm câu hỏi
                        </label>

                        <input asp-for="Score"
                               type="number"
                               step="0.1"
                               min="0"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Audio câu hỏi
                        </label>

                        <input type="file"
                               name="audioFile"
                               accept="audio/*"
                               class="form-control" />

                        @if (!string.IsNullOrEmpty(Model.AudioPath))
                        {
                            <audio controls
                                   class="mt-2 w-100">
                                <source src="@Model.AudioPath" />
                            </audio>
                        }

                    </div>

                </div>

            </div>

        </div>

        <div id="singleChoiceBox"
             class="card shadow-sm mb-4 type-box">

            <div class="card-header">
                <h5 class="mb-0">
                    Single Choice
                </h5>
            </div>

            <div class="card-body">

                @for (int i = 0; i < 4; i++)
                {
                    string optionValue =
                        i < options.Count
                        ? options[i]
                        : "";

                    bool isChecked =
    answers.Contains(optionValue);


                    <div class="d-flex align-items-center mb-3">

                        <input type="radio"
                               name="answers"
                               value="@optionValue"
                               class="form-check-input me-2 answer-selector"
                        @(isChecked ? "checked" : "") />

                        <label class="me-2 fw-bold">
                            @letters[i].
                        </label>

                        <input name="options"
                               value="@optionValue"
                               class="form-control option-input"
                               placeholder="Nhập đáp án @letters[i]" />

                    </div>
                }

            </div>

        </div>
        <div id="multipleChoiceBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                <h5 class="mb-0">
                    Multiple Choice
                </h5>
            </div>

            <div class="card-body">

                @for (int i = 0; i < 4; i++)
                {
                    string optionValue =
                        i < options.Count
                        ? options[i]
                        : "";

                    bool isChecked =
    answers.Contains(optionValue);


                    <div class="d-flex align-items-center mb-3">

                        <input type="checkbox"
                               name="answers"
                               value="@optionValue"
                               class="form-check-input me-2 answer-selector"
                        @(isChecked ? "checked" : "") />

                        <label class="me-2 fw-bold">
                            @letters[i].
                        </label>

                        <input name="options"
                               value="@optionValue"
                               class="form-control option-input"
                               placeholder="Nhập đáp án @letters[i]" />

                    </div>
                }

            </div>

        </div>
        <div id="trueFalseBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                <h5 class="mb-0">
                    True / False
                </h5>
            </div>

            <div class="card-body">

                <div class="form-check mb-3">

                    <input type="radio"
                           name="answers"
                           value="Đúng"
                           class="form-check-input"
                    @(answers.Contains("Đúng")
                               ? "checked"
                               : "") />

                    <label class="form-check-label">
                        Đúng
                    </label>

                </div>

                <div class="form-check">

                    <input type="radio"
                           name="answers"
                           value="Sai"
                           class="form-check-input"
                    @(answers.Contains("Sai")
                               ? "checked"
                               : "") />

                    <label class="form-check-label">
                        Sai
                    </label>

                </div>

            </div>

        </div>
        <div id="matchingBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                <h5 class="mb-0">
                    Matching
                </h5>
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6">

                        <h5>Cột A</h5>

                        @foreach (var op in options)
                        {
                            <input name="options"
                                   value="@op"
                                   class="form-control mb-2" />
                        }

                    </div>

                    <div class="col-md-6">

                        <h5>Cột B</h5>

                        @foreach (var ans in answers)
                        {
                            <input name="answers"
                                   value="@ans"
                                   class="form-control mb-2" />
                        }

                    </div>

                </div>

            </div>

        </div>

        <div id="fillBlankBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                <h5 class="mb-0">
                    Fill Blank
                </h5>
            </div>

            <div class="card-body">

                <label class="form-label">
                    Đáp án ngắn
                </label>

                <input name="answers"
                       value="@((answers != null ? answers.FirstOrDefault() : ""))"
                       class="form-control" />
            </div>

        </div>
        <div id="essayBox"
             class="card shadow-sm mb-4 type-box d-none">

            <div class="card-header">
                <h5 class="mb-0">
                    Essay
                </h5>
            </div>

            <div class="card-body">

                <label class="form-label">
                    Đáp án tự luận
                </label>

                <textarea name="answers"
                          rows="8"
                          class="form-control">@(string.Join("\n",
              answers ?? new List<string>()))</textarea>

            </div>

        </div>

        <button class="btn btn-primary">
            Cập nhật
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Quay lại
        </a>

    </form>

</div>

<script>

    const typeSelect =
        document.getElementById(
            "questionType");

    const boxes =
    {
        "SingleChoice":
            document.getElementById(
                "singleChoiceBox"),

        "MultipleChoice":
            document.getElementById(
                "multipleChoiceBox"),

        "TrueFalse":
            document.getElementById(
                "trueFalseBox"),

        "Matching":
            document.getElementById(
                "matchingBox"),

        "FillBlank":
            document.getElementById(
                "fillBlankBox"),

        "Essay":
            document.getElementById(
                "essayBox")
    };

        function updateQuestionType()
    {
        document
            .querySelectorAll(".type-box")
            .forEach(box =>
            {
                box.classList.add(
                    "d-none");

                box.querySelectorAll(
                    "input,textarea,select")
                    .forEach(el =>
                    {
                        el.disabled = true;
                    });
            });

        const selected =
            typeSelect.value;

        if (boxes[selected])
        {
            boxes[selected]
                .classList
                .remove("d-none");

            boxes[selected]
                .querySelectorAll(
                    "input,textarea,select")
                .forEach(el =>
                {
                    el.disabled = false;
                });
        }
    }

    document.addEventListener(
    "DOMContentLoaded",
    function ()
    {
        document
            .querySelectorAll(
                ".option-input")
            .forEach(input =>
            {
                const row =
                    input.closest(
                        ".d-flex");

                if (!row) return;

                const selector =
                    row.querySelector(
                        ".answer-selector");

                if (selector)
                {
                    selector.value =
                        input.value;
                }
            });

        updateQuestionType();
    });

    document.addEventListener(
    "input",
    function(e)
    {
        if(
            e.target.classList.contains(
                "option-input"))
        {
            const row =
                e.target.closest(
                    ".d-flex");

            if(!row) return;

            const selector =
                row.querySelector(
                    ".answer-selector");

            if(selector)
            {
                selector.value =
                    e.target.value;
            }
        }
    });

</script>