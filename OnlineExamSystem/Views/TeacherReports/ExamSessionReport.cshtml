@model OnlineExamSystem.ViewModels.ExamReportViewModel

@{
    ViewData["Title"] = "Báo cáo kỳ thi";
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <title>Báo cáo kỳ thi</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

    <div class="container mt-4">

        <div class="row mb-4">

            <div class="col-md-8">

                <h2 class="text-primary">

                    Báo cáo & thống kê kỳ thi

                </h2>

                <p>

                    <strong>Kỳ thi:</strong>

                    @Model.SessionName

                </p>

                <p>

                    <strong>Đề thi:</strong>

                    @Model.ExamTitle

                </p>

            </div>

            <div class="col-md-4 text-end">

                <a asp-controller="TeacherReports"
                   asp-action="ExportExcel"
                   asp-route-examSessionId="@Model.ExamSessionId"
                   class="btn btn-success">

                    Xuất Excel

                </a>

                <a asp-controller="TeacherReports"
                   asp-action="ExportPdf"
                   asp-route-examSessionId="@Model.ExamSessionId"
                   class="btn btn-danger">

                    Xuất PDF

                </a>

            </div>

        </div>
        <div class="row mb-4">

            <div class="col-md-3">

                <div class="card border-primary">

                    <div class="card-body text-center">

                        <h5>Tổng học sinh</h5>

                        <h3>

                            @Model.TotalStudents

                        </h3>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card border-success">

                    <div class="card-body text-center">

                        <h5>Điểm trung bình</h5>

                        <h3>

                            @Model.AverageScore.ToString("0.00")

                        </h3>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card border-warning">

                    <div class="card-body text-center">

                        <h5>Điểm cao nhất</h5>

                        <h3>

                            @Model.HighestScore.ToString("0.00")

                        </h3>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card border-danger">

                    <div class="card-body text-center">

                        <h5>Vi phạm</h5>

                        <h3>

                            @Model.TotalViolations

                        </h3>

                    </div>

                </div>

            </div>

        </div>

        <!-- BIỂU ĐỒ -->

        <div class="row mb-5">

            <div class="col-md-6">

                <div class="card">

                    <div class="card-header">

                        Biểu đồ tròn

                    </div>

                    <div class="card-body">

                        <canvas id="pieChart"></canvas>

                    </div>

                </div>

            </div>

            <div class="col-md-6">

                <div class="card">

                    <div class="card-header">

                        Biểu đồ cột

                    </div>

                    <div class="card-body">

                        <canvas id="barChart"></canvas>

                    </div>

                </div>

            </div>

        </div>
        <div class="card">

            <div class="card-header bg-primary text-white">

                Danh sách kết quả

            </div>

            <div class="card-body">

                <table class="table table-bordered">

                    <thead>

                        <tr>

                            <th>STT</th>

                            <th>Học sinh</th>

                            <th>Điểm</th>

                            <th>Vi phạm</th>

                        </tr>

                    </thead>

                    <tbody>

                        @{
                            int stt = 1;
                        }

                        @if (Model.Results != null &&
                             Model.Results.Count > 0)
                        {
                            foreach (var item in Model.Results)
                            {
                                <tr>

                                    <td>

                                        @stt

                                    </td>

                                    <td>

                                        @(item.Student != null
                                            ? item.Student.Username
                                            : "")

                                    </td>

                                    <td>

                                        @item.Score

                                    </td>

                                    <td>

                                        @item.ViolationCount

                                    </td>

                                </tr>

                                stt++;
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="4"
                                    class="text-center text-danger">

                                    Chưa có dữ liệu

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <script>
        const pieCanvas =
        document.getElementById(
        'pieChart');

        new Chart(pieCanvas, {

        type: 'pie',

        data: {

        labels: [
        'Giỏi',
        'Khá',
        'Trung bình',
        'Yếu'
        ],

        datasets: [{

        data: [

        @Model.ExcellentCount,
        @Model.GoodCount,
        @Model.AverageCount,
        @Model.WeakCount

        ]

        }]
        }
        });
        const barCanvas =
        document.getElementById(
        'barChart');

        new Chart(barCanvas, {

        type: 'bar',

        data: {

        labels: [
        'Điểm TB',
        'Cao nhất',
        'Thấp nhất'
        ],

        datasets: [{

        label: 'Điểm',

        data: [

        @Model.AverageScore,
        @Model.HighestScore,
        @Model.LowestScore

        ]

        }]
        }
        });
        setInterval(function () {

        location.reload();

        }, 30000);

    </script>

</body>

</html>